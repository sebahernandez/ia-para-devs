---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { getCatClass } from '../utils/categories';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { data } = post;

const dateFormatter = new Intl.DateTimeFormat('es-CL', {
  year: 'numeric',
  month: 'long',
  day: '2-digit',
});
---

<BaseLayout
  title={`${data.title} · Blog IA para devs`}
  description={data.description}
  type="article"
  pubDate={data.pubDate}
>
  <article class="mx-auto max-w-5xl px-6 pt-14 pb-20">
    <nav class="mb-10 text-sm">
      <a href="/blog/" class="link">
        ← Todos los artículos
      </a>
    </nav>

    <header class="mb-12">
      <div class="flex flex-wrap items-center gap-3 text-xs text-ink-400">
        <a
          href={`/categorias/${data.category}/`}
          class={`font-mono uppercase tracking-widest transition-[filter] hover:brightness-125 ${getCatClass(data.category)}`}
        >
          {data.category}
        </a>
        <span class="h-1 w-1 rounded-full bg-ink-600"></span>
        <time datetime={data.pubDate.toISOString()}>
          {dateFormatter.format(data.pubDate)}
        </time>
        {
          data.updatedDate && (
            <>
              <span class="h-1 w-1 rounded-full bg-ink-600"></span>
              <span>
                Actualizado el{' '}
                <time datetime={data.updatedDate.toISOString()}>
                  {dateFormatter.format(data.updatedDate)}
                </time>
              </span>
            </>
          )
        }
      </div>

      <h1
        class="mt-5 text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl"
      >
        {data.title}
      </h1>

      <p class="mt-5 text-pretty text-lg leading-relaxed text-ink-200">
        {data.description}
      </p>

      <div class="mt-8 flex items-center gap-3 text-sm text-ink-400">
        <div
          class="flex h-9 w-9 items-center justify-center rounded-full
                 bg-gradient-to-br from-ink-700 to-ink-900 text-ink-100 font-medium"
          aria-hidden="true"
        >
          {data.author.charAt(0)}
        </div>
        <div>
          <p class="font-medium text-ink-100">{data.author}</p>
          <p class="text-xs text-ink-400">Lectura estimada · 5 min</p>
        </div>
      </div>

      <div class="hairline mt-10"></div>
    </header>

    <div class="post-content">
      <slot />
    </div>

    {
      data.tags.length > 0 && (
        <footer class="mt-16">
          <div class="hairline"></div>
          <div class="mt-8 flex flex-wrap items-center gap-2">
            <span class="text-xs uppercase tracking-widest text-ink-400">Tags</span>
            {data.tags.map((t) => (
              <a href={`/tags/${t}/`} class="chip">
                #{t}
              </a>
            ))}
          </div>
        </footer>
      )
    }
  </article>
</BaseLayout>