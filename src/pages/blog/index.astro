---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCatClass } from '../../utils/categories';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const BATCH = 6;

const categories = [...new Set(allPosts.map(p => p.data.category))].sort() as string[];

const labels: Record<string, string> = {
  modelos: 'Modelos',
  herramientas: 'Herramientas',
  investigacion: 'Investigación',
  opinión: 'Opinión',
  tutorial: 'Tutoriales',
};
---

<BaseLayout
  title="Todos los artículos · Blog IA para devs"
  description="Archivo completo de noticias, análisis y tutoriales sobre IA para desarrolladores."
>
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-10">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-400">Archivo</p>
    <h1 class="mt-2 text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl">
      Todos los artículos
    </h1>
    <p class="mt-4 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
      {allPosts.length} publicaciones sobre modelos, herramientas y noticias de IA.
    </p>
  </section>

  <!-- Barra de búsqueda + filtro de categorías -->
  <section class="mx-auto max-w-5xl px-6 pb-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">

      <!-- Buscador -->
      <div class="relative w-full sm:max-w-xs">
        <svg
          class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-ink-500"
          xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Buscar artículos…"
          autocomplete="off"
          class="w-full rounded-lg border border-ink-700 bg-ink-900/60 py-2.5 pl-9 pr-4
                 text-sm text-ink-100 placeholder-ink-500
                 transition-colors duration-200
                 focus:border-ink-500 focus:outline-none focus:ring-1 focus:ring-ink-500"
        />
      </div>

      <!-- Filtro de categorías -->
      <div id="cat-filter" class="flex flex-wrap gap-2">
        <button
          data-cat="all"
          data-active
          class="cat-btn rounded-full border border-ink-600 bg-ink-800 px-3.5 py-1.5
                 text-xs font-medium text-white transition-all duration-200
                 hover:border-ink-400"
        >
          Todos
        </button>
        {categories.map((cat) => (
          <button
            data-cat={cat}
            class={`cat-btn rounded-full border border-ink-700 bg-ink-900/40 px-3.5 py-1.5
                    text-xs font-medium opacity-50 transition-all duration-200
                    hover:border-ink-500 hover:opacity-100 ${getCatClass(cat)}`}
          >
            {labels[cat] ?? cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Estado vacío -->
    <p
      id="no-results"
      class="hidden mt-10 text-center text-sm text-ink-500"
      aria-live="polite"
    >
      No se encontraron artículos para esa búsqueda.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div id="posts-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {allPosts.map((post, i) => (
        <div
          data-post-index={i}
          data-category={post.data.category}
          data-title={post.data.title.toLowerCase()}
          data-desc={post.data.description.toLowerCase()}
          class="post-item"
        >
          <PostCard post={post} />
        </div>
      ))}
    </div>

    <div id="load-more-area" class="mt-12 flex flex-col items-center gap-4 hidden">
      <button
        id="load-more-btn"
        class="group inline-flex items-center gap-2.5 rounded-full border border-ink-700
               bg-ink-900/60 px-6 py-3 text-sm font-medium text-ink-100
               transition-all duration-200
               hover:border-ink-500 hover:bg-ink-800 hover:text-white
               active:scale-95"
        aria-live="polite"
      >
        <svg
          id="btn-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-y-0.5"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
        <span id="btn-label">Ver más</span>
        <span id="btn-count" class="rounded-full bg-ink-800 px-2 py-0.5 text-xs text-ink-400 group-hover:bg-ink-700"></span>
      </button>

      <p id="progress-label" class="text-xs text-ink-500"></p>
    </div>
  </section>
</BaseLayout>

<style>
  .post-item {
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .post-item[data-hidden] {
    display: none;
  }
  .post-item[data-hidden] {
    display: none;
  }
  .post-item[data-entering] {
    opacity: 0;
    transform: translateY(14px);
  }

  /* Botón de categoría activo */
  .cat-btn[data-active] {
    opacity: 1;
    border-color: currentColor;
    background-color: rgb(255 255 255 / 0.06);
  }
  /* "Todos" activo */
  .cat-btn[data-cat="all"][data-active] {
    border-color: rgb(var(--ink-500));
    background-color: rgb(var(--ink-800));
    color: white;
    opacity: 1;
  }
</style>

<script define:vars={{ BATCH }}>
  function setup() {
    const grid        = document.getElementById('posts-grid');
    const area        = document.getElementById('load-more-area');
    const btn         = document.getElementById('load-more-btn');
    const label       = document.getElementById('btn-label');
    const count       = document.getElementById('btn-count');
    const icon        = document.getElementById('btn-icon');
    const progress    = document.getElementById('progress-label');
    const searchInput = document.getElementById('search-input');
    const catBtns     = document.querySelectorAll('.cat-btn');
    const noResults   = document.getElementById('no-results');

    if (!grid || !btn) return; // no estamos en esta página

    const items = Array.from(grid.querySelectorAll('.post-item'));
    let activeCategory = 'all';
    let searchQuery    = '';
    let filtered       = items.slice();
    let shownCount     = BATCH;

    /* ─── Helpers ─────────────────────────────────────────────── */

    function getFiltered() {
      const q = searchQuery.trim().toLowerCase();
      return items.filter(item => {
        const catMatch  = activeCategory === 'all' || item.dataset.category === activeCategory;
        const textMatch = !q || item.dataset.title.includes(q) || item.dataset.desc.includes(q);
        return catMatch && textMatch;
      });
    }

    /* ─── UI del botón ────────────────────────────────────────── */

    function updateLoadMoreUI() {
      const remaining = filtered.length - shownCount;
      count.textContent    = remaining > 0 ? `${remaining} restantes` : '';
      progress.textContent = `Mostrando ${Math.min(shownCount, filtered.length)} de ${filtered.length}`;

      if (remaining <= 0) {
        btn.disabled         = true;
        label.textContent    = 'Todo al día';
        icon.innerHTML       = '<path d="M20 6L9 17l-5-5"/>';
        count.textContent    = '';
      } else {
        btn.disabled      = false;
        label.textContent = 'Ver más';
        icon.innerHTML    = '<path d="M12 5v14M5 12l7 7 7-7"/>';
      }
    }

    /* ─── Renderizar conjunto filtrado con paginación ─────────── */

    function applyFilters() {
      filtered   = getFiltered();
      shownCount = BATCH;

      items.forEach(item => {
        const idx = filtered.indexOf(item);
        if (idx === -1 || idx >= shownCount) {
          item.setAttribute('data-hidden', '');
        } else {
          item.removeAttribute('data-hidden');
        }
      });

      noResults.classList.toggle('hidden', filtered.length > 0);

      if (filtered.length > BATCH) {
        area.classList.remove('hidden');
        updateLoadMoreUI();
      } else {
        area.classList.add('hidden');
      }
    }

    /* ─── Categorías ──────────────────────────────────────────── */

    catBtns.forEach(catBtn => {
      catBtn.addEventListener('click', () => {
        catBtns.forEach(b => b.removeAttribute('data-active'));
        catBtn.setAttribute('data-active', '');
        activeCategory = catBtn.dataset.cat;
        applyFilters();
      });
    });

    /* ─── Buscador ────────────────────────────────────────────── */

    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value;
      applyFilters();
    });

    /* ─── Cargar más ──────────────────────────────────────────── */

    function revealNext() {
      btn.disabled      = true;
      label.textContent = 'Cargando';
      icon.innerHTML    = `<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83
               M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>`;
      icon.style.animation = 'spin 0.7s linear infinite';

      setTimeout(() => {
        const next = filtered.slice(shownCount, shownCount + BATCH);

        next.forEach(item => {
          item.removeAttribute('data-hidden');
          item.setAttribute('data-entering', '');
        });
        requestAnimationFrame(() => {
          next.forEach((item, i) => setTimeout(() => item.removeAttribute('data-entering'), i * 70));
        });

        shownCount = Math.min(shownCount + BATCH, filtered.length);

        icon.style.animation = '';
        icon.innerHTML       = '<path d="M12 5v14M5 12l7 7 7-7"/>';
        label.textContent    = 'Ver más';
        btn.disabled         = false;

        updateLoadMoreUI();
        next[0]?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 320);
    }

    btn.addEventListener('click', revealNext);
    applyFilters();
  }

  // Se ejecuta en carga inicial y en cada navegación con View Transitions
  document.addEventListener('astro:page-load', setup);
</script>

<style is:global>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
