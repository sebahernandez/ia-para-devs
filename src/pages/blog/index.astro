---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const BATCH = 6;
---

<BaseLayout
  title="Todos los artículos · Blog IA para devs"
  description="Archivo completo de noticias, análisis y tutoriales sobre IA para desarrolladores."
>
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-16">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-400">Archivo</p>
    <h1 class="mt-2 text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl">
      Todos los artículos
    </h1>
    <p class="mt-4 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
      {allPosts.length} publicaciones sobre modelos, herramientas y noticias de IA.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div id="posts-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {allPosts.map((post, i) => (
        <div data-post-index={i} class="post-item">
          <PostCard post={post} />
        </div>
      ))}
    </div>

    <div id="load-more-area" class="mt-12 flex flex-col items-center gap-4 hidden">
      <button
        id="load-more-btn"
        class="group inline-flex items-center gap-2.5 rounded-full border border-ink-700
               bg-ink-900/60 px-6 py-3 text-sm font-medium text-ink-100
               transition-all duration-200
               hover:border-ink-500 hover:bg-ink-800 hover:text-white
               active:scale-95"
        aria-live="polite"
      >
        <svg
          id="btn-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-y-0.5"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
        <span id="btn-label">Ver más</span>
        <span id="btn-count" class="rounded-full bg-ink-800 px-2 py-0.5 text-xs text-ink-400 group-hover:bg-ink-700"></span>
      </button>

      <p id="progress-label" class="text-xs text-ink-500"></p>
    </div>
  </section>
</BaseLayout>

<style>
  .post-item {
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .post-item[data-hidden] {
    display: none;
  }
  .post-item[data-entering] {
    opacity: 0;
    transform: translateY(14px);
  }
</style>

<script define:vars={{ BATCH, total: allPosts.length }}>
  const grid = document.getElementById('posts-grid');
  const area = document.getElementById('load-more-area');
  const btn  = document.getElementById('load-more-btn');
  const label = document.getElementById('btn-label');
  const count = document.getElementById('btn-count');
  const icon  = document.getElementById('btn-icon');
  const progress = document.getElementById('progress-label');

  const items = Array.from(grid.querySelectorAll('.post-item'));
  let shown = BATCH;

  function updateUI() {
    const remaining = total - shown;
    count.textContent = remaining > 0 ? `${remaining} restantes` : '';
    progress.textContent = `Mostrando ${Math.min(shown, total)} de ${total}`;

    if (remaining <= 0) {
      btn.disabled = true;
      label.textContent = 'Todo al día';
      icon.innerHTML = '<path d="M20 6L9 17l-5-5"/>';
      count.textContent = '';
    }
  }

  function init() {
    // Ocultar posts más allá del primer batch
    items.forEach((item, i) => {
      if (i >= shown) item.setAttribute('data-hidden', '');
    });

    if (total > BATCH) {
      area.classList.remove('hidden');
      updateUI();
    }
  }

  function revealNext() {
    // Estado de carga
    btn.disabled = true;
    label.textContent = 'Cargando';
    icon.innerHTML = `
      <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83
               M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
    `;
    icon.style.animation = 'spin 0.7s linear infinite';

    setTimeout(() => {
      const next = items.slice(shown, shown + BATCH);

      // Marcar como "entrando" antes de mostrar para tener el estado inicial de la transición
      next.forEach(item => {
        item.removeAttribute('data-hidden');
        item.setAttribute('data-entering', '');
      });

      // Un frame después: arrancar transición con stagger
      requestAnimationFrame(() => {
        next.forEach((item, i) => {
          setTimeout(() => {
            item.removeAttribute('data-entering');
          }, i * 70);
        });
      });

      shown = Math.min(shown + BATCH, total);

      // Restaurar botón
      icon.style.animation = '';
      icon.innerHTML = '<path d="M12 5v14M5 12l7 7 7-7"/>';
      label.textContent = 'Ver más';
      btn.disabled = false;

      updateUI();

      // Scroll suave al primer card nuevo
      next[0]?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 320);
  }

  btn.addEventListener('click', revealNext);
  init();
</script>

<style is:global>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
