---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 · Blog IA para devs"
  description="La página que buscas no existe."
>
  <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-400">Error 404</p>
    <h1 class="mt-3 text-balance text-5xl font-semibold tracking-tight text-white sm:text-6xl">
      No hay nada aquí.
    </h1>
    <p class="mt-4 max-w-md text-pretty text-lg leading-relaxed text-ink-300">
      La página que buscas no existe o se movió. Pero seguro hay algo
      interesante en el archivo.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-md bg-white px-4 py-2.5 text-sm font-medium text-ink-950"
      >
        Volver al inicio
      </a>
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 rounded-md border border-ink-700 px-4 py-2.5 text-sm font-medium text-ink-100 hover:border-ink-500"
      >
        Ver artículos
      </a>
    </div>
  </section>
</BaseLayout>