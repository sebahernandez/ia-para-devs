---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const byCategory = new Map<string, number>();
for (const p of allPosts) {
  byCategory.set(p.data.category, (byCategory.get(p.data.category) ?? 0) + 1);
}

const labels: Record<string, string> = {
  modelos: 'Modelos',
  herramientas: 'Herramientas',
  investigacion: 'Investigación',
  opinión: 'Opinión',
  tutorial: 'Tutoriales',
};

const descriptions: Record<string, string> = {
  modelos:
    'Lanzamientos, comparativas y benchmarks de modelos de lenguaje, visión, audio y código.',
  herramientas:
    'SDKs, IDEs, agentes y utilidades prácticas para integrar IA en tu flujo de trabajo.',
  investigacion:
    'Papers, técnicas nuevas y movimientos importantes que definen el estado del arte.',
  opinión:
    'Análisis editorial sobre hacia dónde va la industria y qué significa para los devs.',
  tutorial:
    'Guías paso a paso con código, prompts y arquitecturas listas para producción.',
};

const categories = [...byCategory.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([cat, count]) => ({
    slug: cat,
    label: labels[cat] ?? cat,
    desc: descriptions[cat] ?? '',
    count,
  }));
---

<BaseLayout
  title="Categorías · Blog IA para devs"
  description="Explora los artículos del blog por categoría."
>
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-16">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-400">Índice</p>
    <h1 class="mt-2 text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl">
      Categorías
    </h1>
    <p class="mt-4 max-w-2xl text-pretty text-lg leading-relaxed text-ink-300">
      Encuentra contenido por tema.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="grid gap-4 sm:grid-cols-2">
      {
        categories.map(({ slug, label, desc, count }) => (
          <a
            href={`/categorias/${slug}/`}
            class="group flex flex-col rounded-xl border border-ink-800 bg-ink-900/40 p-6
                   transition-all hover:border-ink-600 hover:bg-ink-900/70"
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs uppercase tracking-widest text-ink-400">
                {label}
              </span>
              <span class="font-mono text-xs text-ink-400">
                {count} {count === 1 ? 'post' : 'posts'}
              </span>
            </div>
            <h2 class="mt-3 text-lg font-semibold tracking-tight text-white">{label}</h2>
            <p class="mt-2 text-sm leading-relaxed text-ink-300">{desc}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>